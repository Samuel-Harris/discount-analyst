# Long-lived sandbox used by the agent-terminal orchestrator (docker exec).
# Build: docker build -f backend/services/agent_terminal/Dockerfile.sandbox -t discount-analyst-terminal-sandbox:local .
FROM python:3.14.5-slim-trixie

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /workspace

RUN apt-get update \
    && apt-get upgrade -y --no-install-recommends \
    && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY backend/services/agent_terminal/requirements-sandbox.txt /tmp/requirements-sandbox.txt
RUN pip install --upgrade pip \
    && pip install -r /tmp/requirements-sandbox.txt \
    && rm /tmp/requirements-sandbox.txt

# Default idle command; orchestrator overrides with sleep infinity.
CMD ["sleep", "infinity"]
