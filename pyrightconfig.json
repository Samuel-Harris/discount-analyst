{
  "venvPath": ".",
  "venv": ".venv",
  "include": [
    "backend/**/*.py",
    "discount_analyst/**/*.py",
    "docker/agent-terminal/**/*.py",
    "scripts/**/*.py",
    "tests/**/*.py"
  ],
  "exclude": [
    "**/__pycache__/**",
    "**/.venv/**",
    "**/venv/**",
    "discount_analyst/notebooks/**"
  ],
  "typeCheckingMode": "strict",
  "pythonVersion": "3.14",
  "reportUnknownVariableType": true
}
